# BesaChain Deployment Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# General Configuration
# =============================================================================
NODE_ENV=production
DOMAIN=besachain.com
ORG_DOMAIN=besachain.org

# =============================================================================
# Blockchain Configuration
# =============================================================================
CHAIN_ID=25000
RPC_URL=https://rpc.besachain.com
WS_URL=wss://ws.besachain.com
API_URL=https://api.besachain.com

# =============================================================================
# DEX Configuration
# =============================================================================
DEX_API_URL=https://api.dex.besachain.com
DEX_WS_URL=wss://ws.dex.besachain.com

# =============================================================================
# Faucet Configuration
# =============================================================================
# WARNING: Store this securely! The faucet private key for distributing testnet funds
FAUCET_PRIVATE_KEY=your_faucet_private_key_here
FAUCET_AMOUNT=0.1
RATE_LIMIT_MINUTES=60

# reCAPTCHA v2 or v3 secret key for faucet protection
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# =============================================================================
# Bridge Configuration
# =============================================================================
# Layer 1 (Ethereum mainnet or testnet) RPC
L1_RPC_URL=https://ethereum-rpc.example.com
L2_RPC_URL=https://rpc.besachain.com

# Bridge contract addresses
BRIDGE_CONTRACT_L1=0x...
BRIDGE_CONTRACT_L2=0x...

CHAIN_ID_L1=1
CHAIN_ID_L2=25000

# =============================================================================
# SSL/Domain Configuration
# =============================================================================
# Email for Let's Encrypt notifications
LETSENCRYPT_EMAIL=admin@besachain.com

# =============================================================================
# Monitoring & Alerts (Optional)
# =============================================================================
# Sentry DSN for error tracking
SENTRY_DSN=

# Log level: debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# Contact Information
# =============================================================================
CONTACT_EMAIL=admin@besachain.com
SUPPORT_EMAIL=support@besachain.com
FOUNDATION_EMAIL=foundation@besachain.org

# =============================================================================
# Deployment Settings
# =============================================================================
# Docker image registry (if using private registry)
DOCKER_REGISTRY=
IMAGE_TAG=latest

# Backup settings
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
